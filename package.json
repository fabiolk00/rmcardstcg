{
  "name": "rm-cards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:nplusone": "vitest run tests/nplusone",
    "test:concurrency": "vitest run tests/concurrency",
    "test:db": "tsx scripts/test-with-ephemeral-pg.ts",
    "test:e2e": "tsx scripts/e2e-with-ephemeral-pg.ts",
    "harness": "tsx scripts/harness-with-ephemeral-pg.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:test:setup": "prisma db push --accept-data-loss && tsx scripts/apply-test-constraints.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.4",
    "svix": "^1.95.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "embedded-postgres": "18.4.0-beta.17"
  },
  "packageManager": "pnpm@10.32.1"
}
