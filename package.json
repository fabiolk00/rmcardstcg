    "resend": "^6.12.4",
    "svix": "^1.95.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
