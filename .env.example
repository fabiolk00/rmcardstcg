# RM Cards — variaveis de ambiente
# Copie para .env.local e preencha. .env.local NAO vai para o git.
# Durante o dev mock-first, deixar vazio nao quebra a aplicacao.

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Signing secret do endpoint de webhook (painel Clerk > Webhooks). Verifica a
# assinatura svix em /api/webhooks/clerk.
CLERK_WEBHOOK_SECRET=
# E-mails (separados por virgula) que recebem role admin ao sincronizar — bootstrap
# do admin sem mexer no banco. Ex.: ADMIN_EMAILS="voce@exemplo.com"
ADMIN_EMAILS=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/entrar
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/criar-conta
# Pos-login: o destino real e decidido por ROLE no roteador /pos-login (admin ->
# painel, cliente -> minhas-compras). O prop fallbackRedirectUrl no <SignIn>/<SignUp>
# e autoritativo (vence estas envs); manter aqui so para documentar o fallback.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/pos-login
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/pos-login

# Supabase / Postgres
# Obrigatorios a partir do F10. DATABASE_URL: pooler (porta 6543), usado em
# runtime. DIRECT_URL: conexao direta (porta 5432), usada nas migrations.
# Ex.: postgresql://postgres:SENHA@HOST:6543/postgres?pgbouncer=true
DATABASE_URL=
DIRECT_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Upload de imagem de produto (admin) -> Supabase Storage. Usa NEXT_PUBLIC_SUPABASE_URL
# + SUPABASE_SERVICE_ROLE_KEY acima. Bucket PUBLICO (default "tcg"). Opcional: so
# defina se usar outro nome. Sem as envs de URL/key o upload fica desligado (mock-first).
SUPABASE_STORAGE_BUCKET=tcg

# Asaas (pagamento — sandbox no MVP)
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
# A chave do Asaas comeca com "$". Escape como "\$..." entre aspas, senao o
# dotenv-expand do Next interpreta como variavel e a chave carrega vazia.
# Ex.: ASAAS_API_KEY="\$aact_hmlg_...."
ASAAS_API_KEY=
# Token que o Asaas envia no header asaas-access-token. Gere em Integracoes >
# Webhooks no painel do Asaas e use exatamente o mesmo valor aqui.
ASAAS_WEBHOOK_TOKEN=

# Resend (e-mail transacional). Sem chave, os envios viram no-op (mock-first).
RESEND_API_KEY=
# Remetente verificado no Resend. Ex.: RESEND_FROM_EMAIL="RM Cards <pedidos@seudominio.com>"
RESEND_FROM_EMAIL=

# SuperFrete (calculo de frete via agregador). Sem token, o calculo fica DESLIGADO
# (mock-first: cai no frete flat de lib/cart/totals). O token e POR AMBIENTE
# (sandbox/producao), gerado no painel SuperFrete > Integracoes/Token. Em producao,
# troque a URL para https://api.superfrete.com e use o token de producao.
SUPERFRETE_API_URL=https://sandbox.superfrete.com
SUPERFRETE_TOKEN=
# User-Agent obrigatorio pela API: identifique a aplicacao + e-mail de contato.
SUPERFRETE_USER_AGENT=RM Cards (contato@rmcardstcg.com.br)
# CEP de origem da loja (de onde os pedidos saem) — o "from" da cotacao. So digitos.
SUPERFRETE_FROM_CEP=
# Cache OPCIONAL da cotacao (read-only/idempotente), em memoria por instancia. TTL em
# ms; 0/ausente => DESLIGADO (default). Use um TTL curto (ex.: 300000 = 5 min) para
# evitar repetir a chamada externa em rajada sem servir tabela de frete velha.
SUPERFRETE_CACHE_TTL_MS=

# pg_cron / reconciliacao
# Segredo compartilhado entre o job pg_cron (rmcards-reconcile-pending-orders) e a
# rota interna /api/internal/reconcile-orders. O pg_cron envia no header
# x-cron-secret (via pg_net); a rota compara em tempo constante. Sem este valor a
# rota responde 500 (fail-closed). No banco (Supabase), defina TAMBEM as GUCs que
# o job le (uma vez, fora do git):
#   ALTER DATABASE postgres SET app.settings.reconcile_url    = 'https://SEU_HOST/api/internal/reconcile-orders';
#   ALTER DATABASE postgres SET app.settings.reconcile_secret = '<MESMO_VALOR_ABAIXO>';
CRON_RECONCILE_SECRET=
